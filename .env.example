# ============================================================
# iCarSP - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no git.
# Configure estas variáveis também no painel do Netlify:
# Site settings > Environment variables
# ============================================================

# --- Consultar Placa API ---
CONSULTARPLACA_EMAIL=seu-email@exemplo.com
CONSULTARPLACA_API_KEY=sua-chave-aqui

# --- Mercado Pago ---
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- URL do site (usada para chamadas internas entre funções) ---
# Em produção: https://www.icarsp.com.br
# Em desenvolvimento local: http://localhost:8888
SITE_URL=https://www.icarsp.com.br

# --- MailerSend (envio de contratos por e-mail) ---
MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic (leitura de CRLV via IA) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
